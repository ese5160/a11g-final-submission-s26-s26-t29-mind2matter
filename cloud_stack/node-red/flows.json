    "z": "tab_ingest",
    "name": "Format Status Summary",
    "func": "const p = msg.payload || {};\nmsg.payload = [\n  `wifi=${p.wifi}`,\n  `mqtt=${p.mqtt}`,\n  `battery=${p.battery_pct ?? '?'}%`,\n  `voice_busy=${p.voice_busy}`,\n  `fall_pending=${p.fall_pending}`,\n  `debug_led=${p.debug_led}`,\n  `fw=${p.fw_version || '-'}`,\n  `uptime_s=${p.uptime_s ?? '-'}`\n].join(' | ');\nreturn msg;",
    "outputs": 1,
    "noerr": 0,
