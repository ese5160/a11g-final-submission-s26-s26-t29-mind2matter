    "id": "http_ai_request",
    "type": "http request",
    "z": "tab_ai",
    "name": "POST AI Worker",
    "method": "POST",
    "ret": "obj",
    "paytoqs": "ignore",
    "url": "",
    "persist": false,
    "authType": "",
    "senderr": false,
    "x": 890,
