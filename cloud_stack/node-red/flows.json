  {
    "id": "fn_prepare_ai_call",
    "type": "function",
    "z": "tab_ai",
    "name": "Summarize + Build HTTP Call",
    "func": "const p = msg.payload || {};\nconst summary = {\n  payload: `${p.request_id || '-'} | mode=${p.mode || '-'} | audio=${p.audio_url || '-'} | image=${p.image_url || 'none'}`\n};\nmsg.url = 'http://aiworker:8000/api/voice-request';\nmsg.headers = { 'content-type': 'application/json' };\nmsg.payload = p;\nreturn [summary, msg];",
    "outputs": 2,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 620,
    "y": 120,
    "wires": [["ui_text_request"], ["http_ai_request"]]
