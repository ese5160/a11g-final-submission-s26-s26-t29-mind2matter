  },
  {
    "id": "switch_ai_status",
    "type": "switch",
    "z": "tab_ai",
    "name": "HTTP 200?",
    "property": "statusCode",
    "propertyType": "msg",
    "rules": [
      {
        "t": "eq",
        "v": "200",
        "vt": "num"
      },
      {
        "t": "else"
      }
    ],
    "checkall": "true",
    "repair": false,
    "outputs": 2,
    "x": 1110,
    "y": 140,
    "wires": [["fn_ai_success"], ["fn_ai_failure"]]
  },
  {
    "id": "fn_ai_success",
    "type": "function",
    "z": "tab_ai",
    "name": "Build MQTT Voice Reply",
    "func": "const p = msg.payload || {};\nconst reply = {\n  request_id: p.request_id,\n  text: p.text || 'No response generated.',\n  audio_url: p.audio_url || '',\n  format: p.format || 'wav',\n  sample_rate_hz: p.sample_rate_hz || 24000\n};\nconst mqttMsg = {\n  topic: 'mind2matter/cloud/glasses01/voice/reply',\n  payload: JSON.stringify(reply)\n};\nconst uiMsg = {\n  payload: `${reply.request_id || '-'} | ${reply.text}`\n};\nreturn [mqttMsg, uiMsg];",
    "outputs": 2,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 1330,
    "y": 100,
    "wires": [["mqtt_out_cloud"], ["ui_text_reply"]]
  },
  {
    "id": "fn_ai_failure",
    "type": "function",
    "z": "tab_ai",
    "name": "Build MQTT Notice",
    "func": "let detail = '';\nif (msg.payload && typeof msg.payload === 'object' && msg.payload.detail) {\n  detail = msg.payload.detail;\n} else if (typeof msg.payload === 'string') {\n  detail = msg.payload;\n} else {\n  detail = JSON.stringify(msg.payload || {});\n}\nconst notice = {\n  type: 'ai_error',\n  statusCode: msg.statusCode || 500,\n  detail,\n  issued_at: new Date().toISOString()\n};\nconst mqttMsg = {\n  topic: 'mind2matter/cloud/glasses01/system/notice',\n  payload: JSON.stringify(notice)\n};\nconst uiMsg = {\n  payload: `AI worker error (${notice.statusCode}): ${detail}`\n};\nreturn [mqttMsg, uiMsg];",
    "outputs": 2,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 1320,
    "y": 180,
    "wires": [["mqtt_out_cloud"], ["ui_text_notice"]]
  },
